[Unit]
Description=Test Quadlet for podfather - APP CONTAINER

[Container]
ContainerName=test-quadlet-app
Image=docker.io/alpine:latest
Pod=test-quadlet.pod
StartWithPod=true
Volume=./resource/test-quadlet-app/private.key:/tmp/private.key:ro,Z
Volume=./resource/test-quadlet-app/index.html:/tmp/index.html:ro,Z
Secret=test-quadlet_TEST-SECRET,type=env,target=TEST-SECRET
Environment=TEST_ENV1=value1
Environment=TEST_ENV2=value2
Exec=sleep infinity

[Service]
Restart=no
